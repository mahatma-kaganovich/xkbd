#!/bin/bash

_help(){
echo "$0: unknown param: $i
Params:
  --nokill
  --[ext]lock [</usr/bin/slock>]
  --test-touch
  --sudo{1|2} <cmd>
  --conf <xkbd_config>
  --displays
  --xrdb
  --boot
  --dpms [on|off|auto]
  --next [cfg|patch]
Examples:
  $0 --nokill --test-touch --lock - on .Xinitrc
  $0 --lock - lock with xkbd
 {
 # .xinitrc
  nrg=/usr/sbin/ya-nrg
  xkbd-onoff --sudo2 \$nrg bat restore --sudo1 \$nrg light 20 cores 0 auto --boot -xss
 }

"
exit 1
}

_deflock(){
	[ -v $1 ] || return 1
	[ -n "${!1}" ] && return 0
	local i
	for i in /usr/bin/slock; do [ -x "$i" ] && break;done
	eval "$1=\"\$i\""
}

_kill(){
	if [ -x /usr/bin/pkill ]; then
		pkill -x xkbd -u "$EUID" ${@} && exit
	else
		killall -qw xkbd -u "$USER" ${@} && exit
	fi
}

pchk(){
	$boot && return 1
	pgrep -x "${1##*/}" -u "$EUID" >/dev/null
}

_bool(){
	case "${1,,}" in
	true|yes|on|1)echo "$2=\"\$$2\";";;
	false|no|off|0)echo "unset $2;";;
	esac
}

_sec(){
	local v=$1 h m
	if [ -n "$v" -a -z "${v//[0-9:]}" ]; then
		s="${v##*:}"
		if [ "$s" = "$v" ]; then
			v=$[s*60]
		else
			v="${v%:*}"
			m="${v##*:}"
			m="${m:-0}"
			v="${v%:*}"
			h="${v##*:}"
			h="${h:-0}"
			v=$[h*60*60+m*60+s]
		fi
		echo "$2=$v;"
	else
		echo "unset $2;"
	fi
}

_xss(){
	xssevent $0 --conf $conf ${sudo1:+--sudo1 $sudo1} ${sudo2:+--sudo2 $sudo2} --lock $lock --extlock $lock --xrdb --xss &
}

_dpms(){
	[ "$dpms" = off ] && return
	$dpmsenabled || return
	local x1=${1:-0} x2=${2:-0} x3=${3:-0} y1=${4:-0} y2=${5:-0} y3=${6:-0}
	if [ $x2 = 0 ]; then
		[ $x3 != 0 -a $x3 -lt $x1 ] && x3=$x1
		
	else
		[ $x2 -lt $x1 ] && x2=$x1
		[ $x3 != 0 -a $x3 -lt $x2 ] && x3=$x2
	fi
	if [ $y2 = 0 ]; then
		[ $y3 != 0 -a $y3 -lt $y1 ] && x3=$y1
		
	else
		[ $y2 -lt $y1 ] && y2=$y1
		[ $y3 != 0 -a $y3 -lt $y2 ] && y3=$y2
	fi
	[ "$dpms" = on ] || [[ "$(xset q)" == *"Standby: $y1 "*"Suspend: $y2 "*"Off: $y3
"*'DPMS is Enabled'* ]] || return
	xset dpms "$x1" "$x2" "$x3"
}

_setxkbmap(){
	setxkbmap
	[[ -e ~/.Xmodmap ]] && xmodmap ~/.Xmodmap
}

kill=true
unset conf lock lock1 xss dpms next cfg patch
sudo='sudo -n --'
touch=true
boot=false
dpmslockstandby=10
dpmslocksuspend=12
dpmslockoff=14
share=@pkgdatadir@
n=
for i in "${@}"; do
	case "$i" in
	--xrdb)
		eval "$(xrdb -query|while read x y; do
		case "$x" in
		xscreensaver.*:)
			x=${x#*.}
			x=${x%:}
			case "$x" in
			lock|dpmsenabled)_bool "$y" $x;;
			*[^a-z]*);;
			dpms*)_sec "$y" $x;;
			esac
		esac
		done)"
		n=
	;;
	--boot)
		boot=true
		lock="$lock"
		kill=false
		n=
	;;
	--nokill)declare "${i#--no}"=false;n='';;
	--test-touch)
		# probably safer for multiple X
		which xinput >/dev/null && {
			xinput list --long|grep -qF 'Touch mode:' || touch=false
		}
		n=
	;;
	--displays)
		pchk(){
			local i r=1
			for i in $(pgrep -x "${1##*/}" -u "$EUID"); do
				grep -xFzw "DISPLAY=$DISPLAY" /proc/"$i"/environ && r=0 && echo $i
			done
			return $r
		}
		_kill(){
			kill $(pchk "$1") 2>/dev/null
		}
		n=
	;;
	--lock|--conf|--sudo1|--sudo2|--xss|--extlock|--dpms|--next)n="${i#--}";declare $n='';;
	-h|--help)_help;;
	*)
		[ -n "$n" ] && declare $n+="${!n:+ }$i" || _help
	;;
	esac
done

_next(){
	local n=$1 i0 i1 i2
	shift
	read $n <"$cache/$n"  || mkdir -p "$cache"
	unset i0 i1 i2
	for i in "${@}"; do
		[ -e "$i" ] || continue
		case $next in
		patch)
		    patch --dry-run --no-backup-if-mismatch -r - -sfi "$i" "$cfg" >/dev/null || continue
		    [ -v i0 ] || i0=
		;;
		esac
		[ -v i0 ] || i0=$i
		[ "$i1" = "${!n}" ] && i2=$i && break
		i1=$i
	done
	
	[ -v i2 ] && i=$i2 || i=$i0
	declare $n=$i
	echo $i >"$cache/$n"
	echo "next $n = $i"

	[ -e "$cfg" ] || return
	cp "$cfg" "$conf"
	[ -n "$patch" -a -e "$patch" ] && patch --no-backup-if-mismatch -r - -sfi "$i" "$conf"
}

share=/usr/share/xkbd
cache="$HOME/.cache/xkbd"

if [ -v conf ]; then
	true
else
    conf="$cache/xkbd.conf"
    ! [ -v next ] && ! [ -e "$conf" ] && next=cfg && rm "$cache/cfg" -f

    read $n <"$cache/$n"  || mkdir -p "$cache"
    
    case "$next" in
    cfg)
	rm "$cache/patch" -f
	_next cfg {~/.config,/etc}/xkbd{,-config}.conf $share/*.conf;;
    patch)
	read cfg <"$cache/cfg"
	_next patch $share/*.patch
    ;;
    esac
fi 2>/dev/null

opt="-l -k $conf -e $0 --nokill"

if _deflock lock; then
    [ -v xss ] && case "$xss" in
    on);;
    '')_xss;;
    *)exit;;
    esac
    $touch && pchk xkbd && touch=false
    if pchk $lock; then
	$touch || exit
    else
	(
	if [ -n "$sudo2" ]; then
		_dpms "$dpmsstandby" "$dpmssuspend" "$dpmsoff" "$dpmslockstandby" "$dpmslocksuspend" "$dpmslockoff"
		( $lock ; exec $sudo $sudo2 ) &
	else
		_dpms "$dpmslockstandby" "$dpmslocksuspend" "$dpmslockoff" "$dpmsstandby" "$dpmssuspend" "$dpmsoff"
		$lock &
	fi
	pid=$!
	if $touch; then
		_setxkbmap
		xkbd $opt &
		wait -n
	fi
	[ -n "$sudo1" ] && $sudo $sudo1 &
	if $kill; then
		if $touch; then
			wait $pid
			_kill
		else
			sleep 0.5
		fi
	fi
	)
	exit
    fi
elif [ -v xss ]; then
	case "$xss" in
	on)exec $sudo $sudo1;;
	off|disable)
		_deflock extlock && pchk $extlock && exit
		exec $sudo $sudo2
	;;
	cycle);;
	'')_xss;;
	esac
	exit
else
	$kill && _kill
fi
# around bug in configuring keyboard over xorg.conf
_setxkbmap
exec xkbd $opt
